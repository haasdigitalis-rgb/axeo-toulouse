{
  "cleanUrls": true,
  "trailingSlash": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/services-pro/", "destination": "/services-pro/index.html" },
    { "source": "/livraison-repas/", "destination": "/livraison-repas/index.html" },
    { "source": "/mentions-legales/", "destination": "/mentions-legales/index.html" },
    { "source": "/politique-confidentialite/", "destination": "/politique-confidentialite/index.html" }
  ]
} 
